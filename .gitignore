# ---- Data (gitignored from the very first commit, BEFORE any data exists) ----
# Real market data (NASDAQ ITCH / Databento MBO) is large and may be licensed.
# Only data/README.md is tracked; everything else under data/ stays local.
# NOTE: ignore the directory CONTENTS (/data/*), not the directory itself —
# git cannot re-include a file whose parent directory is excluded.
/data/*
!/data/README.md

# ---- Build output ----
/build/
build*/
cmake-build-*/
/dist/
/wheelhouse/
*.egg-info/

# ---- CMake junk ----
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
compile_commands.json

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Compiled artifacts ----
*.so
*.pyd
*.dll
*.dylib
*.o
*.obj
*.a
*.lib
*.exp
*.ilk
*.pdb

# ---- Local agent config (kept local; not published in this portfolio repo) ----
.claude/
CLAUDE.md

# ---- Private planning docs (personal / not for publication) ----
Trading_System_Roadmap.md
# Personal interview prep (defense one-liners); kept local, not published.
docs/interview-cheatsheet.md

# ---- Editor / OS ----
.vscode/
.idea/
*.swp
